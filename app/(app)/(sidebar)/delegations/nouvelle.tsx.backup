  switchLabel: {
    fontSize: 14,
    color: '#1F2937',
  },
  permanentContainer: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
    marginTop: 8,
  },
  permanentHint: {
    fontSize: 13,
    color: '#10B981',
  },
