    fontWeight: '500',
    color: theme.colors.primary.DEFAULT,
    paddingHorizontal: 20,
    paddingTop: 12,
    paddingBottom: 4,
  },
  tabsContainer: {
    flexDirection: 'row',
    paddingHorizontal: 20,
    paddingVertical: 8,
    gap: 12,
