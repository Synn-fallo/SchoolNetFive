    backgroundColor: '#F3F4F6',
  },
  tabActive: {
    backgroundColor: theme.colors.primary.DEFAULT,
  },
  tabText: {
    fontSize: 12,
    fontWeight: '500',
    color: '#6B7280',
  },
  tabTextActive: {
    color: '#FFFFFF',
  },
  modalBody: {
    maxHeight: 500,
    paddingHorizontal: 20,
  },
  infoText: {
    fontSize: 13,
    color: '#6B7280',
    paddingVertical: 12,
  },
  sectionItem: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    paddingVertical: 12,
    borderBottomWidth: 1,
    borderBottomColor: '#F3F4F6',
  },
  sectionInfo: {
    flex: 1,
    marginRight: 12,
  },
  sectionLabel: {
    fontSize: 14,
    fontWeight: '500',
    color: '#1F2937',
    marginBottom: 2,
  },
